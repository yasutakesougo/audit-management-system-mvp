{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": ["http://127.0.0.1:4173/analysis/dashboard"],
      "startServerCommand": "if [ ! -f dist/index.html ]; then npm run perf:build || exit 1; fi; vite preview --host 127.0.0.1 --port 4173 --strictPort",
      "startServerReadyPattern": "Local:",
      "startServerReadyTimeout": 300000
    },
    "assert": {
      "assertions": {
        "first-contentful-paint": ["warn", { "maxNumericValue": 3800 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4700 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "interactive": ["warn", { "maxNumericValue": 4700 }],
        "categories:performance": ["warn", { "minScore": 0.72 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "lhci-artifacts/${GITHUB_RUN_ID}"
    }
  }
}
