rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function orgClaimMatches(orgId) {
      return signedIn()
        && request.auth.token.orgId is string
        && request.auth.token.orgId == orgId;
    }

    match /orgs/{orgId}/events/{eventId} {
      allow read: if orgClaimMatches(orgId);

      allow create: if orgClaimMatches(orgId)
        && request.resource.data.orgId == orgId
        && !exists(/databases/$(database)/documents/orgs/$(orgId)/events/$(eventId));

      allow update, delete: if false;
    }

    match /orgs/{orgId}/dailySnapshots/{snapId} {
      allow read: if orgClaimMatches(orgId);

      allow create, update: if orgClaimMatches(orgId)
        && request.resource.data.orgId == orgId;

      allow delete: if false;
    }

    // ── Telemetry (Phase 1 Trial Observation) ──────────────────
    // This app uses MSAL (Azure AD) for authentication, not Firebase Auth.
    // request.auth is always null for write operations (anonymous context).
    // Write: validate payload shape and limit document size.
    // Read: allow for authenticated users (anonymous sign-in) for admin dashboard.
    match /telemetry/{docId} {
      allow create: if request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() < 100
        && request.resource.data.keys().size() <= 20;

      // Dashboard read — gated on Firebase anonymous auth
      allow read: if request.auth != null;

      allow update, delete: if false;
    }
  }
}
